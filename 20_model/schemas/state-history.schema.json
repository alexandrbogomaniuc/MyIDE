{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/state-history.schema.json",
  "title": "MyIDE State History",
  "type": "object",
  "additionalProperties": false,
  "required": ["modelVersion", "stateHistoryId", "ids", "references", "validationNotes", "checkpoints", "resumePolicy"],
  "properties": {
    "modelVersion": {
      "type": "string",
      "const": "0.2.0"
    },
    "stateHistoryId": {
      "type": "string",
      "minLength": 1
    },
    "ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "validationNotes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checkpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["checkpointId", "stateId", "createdFrom"],
        "properties": {
          "checkpointId": {
            "type": "string",
            "minLength": 1
          },
          "stateId": {
            "type": "string",
            "minLength": 1
          },
          "createdFrom": {
            "type": "string",
            "enum": ["manual", "mocked-gameState", "server-restart", "imported-proof"]
          },
          "gameStateRef": {
            "type": "string",
            "minLength": 1
          },
          "lastActionRef": {
            "type": "string",
            "minLength": 1
          },
          "snapshot": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "resumePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "fallbackStateId"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["resume-latest", "resume-by-last-action", "manual", "stateless"]
        },
        "fallbackStateId": {
          "type": "string",
          "minLength": 1
        },
        "reconcileLastAction": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["refId", "kind"],
      "properties": {
        "refId": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["evidence", "project", "schema", "runtime", "todo"]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
