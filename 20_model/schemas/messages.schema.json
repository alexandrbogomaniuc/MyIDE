{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/messages.schema.json",
  "title": "MyIDE Messages",
  "type": "object",
  "additionalProperties": false,
  "required": ["modelVersion", "messagePackId", "ids", "references", "validationNotes", "messages"],
  "properties": {
    "modelVersion": {
      "type": "string",
      "const": "0.2.0"
    },
    "messagePackId": {
      "type": "string",
      "minLength": 1
    },
    "ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "validationNotes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["messageId", "category", "defaultText"],
        "properties": {
          "messageId": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": ["status", "cta", "overlay", "error", "debug", "narration"]
          },
          "defaultText": {
            "type": "string",
            "minLength": 1
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["refId", "kind"],
      "properties": {
        "refId": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["evidence", "project", "schema", "runtime", "todo"]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
