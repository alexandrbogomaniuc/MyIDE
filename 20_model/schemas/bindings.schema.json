{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/bindings.schema.json",
  "title": "MyIDE Binding",
  "type": "object",
  "additionalProperties": false,
  "required": ["bindingId", "name", "from", "to"],
  "properties": {
    "bindingId": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["event", "state", "property", "server", "animation", "visibility", "layout"]
    },
    "from": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["event", "state", "property", "server-response", "animation", "timer"]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "to": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["scene-node", "state", "animation", "server-call", "project-variable"]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "value": {}
      }
    },
    "transform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "operator": {
          "type": "string",
          "enum": ["assign", "merge", "toggle", "map", "filter", "format", "evaluate"]
        },
        "expression": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "when": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
