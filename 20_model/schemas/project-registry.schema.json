{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/project-registry.schema.json",
  "title": "MyIDE Project Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "workspaceId", "displayName", "implementationScope", "activeProjectId", "projects"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "implementationScope": {
      "type": "string",
      "enum": ["universal-local-first", "slot-first", "reference-only"]
    },
    "activeProjectId": {
      "type": "string",
      "minLength": 1
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./project-metadata.schema.json"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
