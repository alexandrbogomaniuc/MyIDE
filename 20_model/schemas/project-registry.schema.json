{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/project-registry.schema.json",
  "title": "MyIDE Project Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workspaceId",
    "displayName",
    "description",
    "implementationScope",
    "discoveryMode",
    "sourceOfTruth",
    "activeProjectId",
    "projectCount",
    "projects"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "implementationScope": {
      "type": "string",
      "enum": ["universal-local-first", "slot-first", "reference-only"]
    },
    "discoveryMode": {
      "type": "string",
      "const": "folder-scan"
    },
    "sourceOfTruth": {
      "type": "string",
      "const": "project-folders"
    },
    "activeProjectId": {
      "type": "string",
      "minLength": 1
    },
    "projectCount": {
      "type": "integer",
      "minimum": 1
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./project-metadata.schema.json"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
