{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/assets.schema.json",
  "title": "MyIDE Asset Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["assetId", "kind", "role", "provenance"],
  "properties": {
    "assetId": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["image", "audio", "video", "json", "text", "atlas", "font", "shader", "data"]
    },
    "role": {
      "type": "string",
      "enum": ["background", "symbol", "ui", "fx", "audio", "metadata", "reference", "tooling"]
    },
    "mimeType": {
      "type": "string",
      "minLength": 1
    },
    "logicalPath": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": ["editable", "derived", "donor-evidence", "reference"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin"],
      "properties": {
        "origin": {
          "type": "string",
          "enum": ["original", "donor-derived", "reference", "generated"]
        },
        "donorId": {
          "type": "string",
          "minLength": 1
        },
        "evidenceRef": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 0
        },
        "height": {
          "type": "integer",
          "minimum": 0
        },
        "frameCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
