{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/project.schema.json",
  "title": "MyIDE Project",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "projectId", "name", "mode", "sources", "assets", "scenes", "states", "animations", "bindings", "serverMap", "messages", "localization", "clientConfig", "rngSource", "stateHistory"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.2.0"
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "mode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "userScope", "ui"],
      "properties": {
        "product": {
          "type": "string",
          "const": "slot-only"
        },
        "userScope": {
          "type": "string",
          "const": "single-user"
        },
        "ui": {
          "type": "string",
          "const": "desktop-web-ui"
        }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["editableRoot", "donorEvidenceRoot", "rawDonorRoots"],
      "properties": {
        "editableRoot": {
          "type": "string",
          "minLength": 1
        },
        "donorEvidenceRoot": {
          "type": "string",
          "minLength": 1
        },
        "rawDonorRoots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primaryDonorId": {
          "type": "string",
          "minLength": 1
        },
        "secondaryDonorIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "todo": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "./assets.schema.json"
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "$ref": "./scene.schema.json"
      }
    },
    "states": {
      "type": "array",
      "items": {
        "$ref": "./states.schema.json"
      }
    },
    "animations": {
      "type": "array",
      "items": {
        "$ref": "./animations.schema.json"
      }
    },
    "bindings": {
      "type": "array",
      "items": {
        "$ref": "./bindings.schema.json"
      }
    },
    "serverMap": {
      "$ref": "./server-map.schema.json"
    },
    "messages": {
      "$ref": "./messages.schema.json"
    },
    "localization": {
      "$ref": "./localization.schema.json"
    },
    "clientConfig": {
      "$ref": "./client-config.schema.json"
    },
    "rngSource": {
      "$ref": "./rng-source.schema.json"
    },
    "stateHistory": {
      "$ref": "./state-history.schema.json"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
