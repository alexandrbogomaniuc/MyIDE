{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/scene.schema.json",
  "title": "MyIDE Scene",
  "type": "object",
  "additionalProperties": false,
  "required": ["sceneId", "name", "kind", "layers"],
  "properties": {
    "sceneId": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["boot", "gameplay", "preview", "overlay", "menu", "debug", "transition"]
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 0
        },
        "height": {
          "type": "integer",
          "minimum": 0
        },
        "safeArea": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "top": {
              "type": "number"
            },
            "right": {
              "type": "number"
            },
            "bottom": {
              "type": "number"
            },
            "left": {
              "type": "number"
            }
          }
        }
      }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layerId", "name", "role", "nodes"],
        "properties": {
          "layerId": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": ["background", "midground", "foreground", "ui", "fx", "debug"]
          },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["nodeId", "type", "position"],
              "properties": {
                "nodeId": {
                  "type": "string",
                  "minLength": 1
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "type": {
                  "type": "string",
                  "enum": ["sprite", "text", "container", "shape", "video", "particle", "hotspot", "webview"]
                },
                "assetRef": {
                  "type": "string",
                  "minLength": 1
                },
                "position": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["x", "y"],
                  "properties": {
                    "x": {
                      "type": "number"
                    },
                    "y": {
                      "type": "number"
                    },
                    "width": {
                      "type": "number"
                    },
                    "height": {
                      "type": "number"
                    },
                    "anchorX": {
                      "type": "number"
                    },
                    "anchorY": {
                      "type": "number"
                    },
                    "scaleX": {
                      "type": "number"
                    },
                    "scaleY": {
                      "type": "number"
                    },
                    "rotation": {
                      "type": "number"
                    }
                  }
                },
                "visible": {
                  "type": "boolean",
                  "default": true
                },
                "children": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "bindings": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "extensions": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "zoom": {
          "type": "number"
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
