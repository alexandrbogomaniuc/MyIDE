{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/workspace.schema.json",
  "title": "MyIDE Workspace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workspaceId",
    "displayName",
    "description",
    "implementationScope",
    "activeProjectId",
    "registryPath",
    "source",
    "selectedProjectId",
    "projects"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "implementationScope": {
      "type": "string",
      "enum": ["universal-local-first", "slot-first", "reference-only"]
    },
    "activeProjectId": {
      "type": "string",
      "minLength": 1
    },
    "registryPath": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registryFound", "note"],
      "properties": {
        "registryFound": {
          "type": "boolean"
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "selectedProjectId": {
      "type": "string",
      "minLength": 1
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "projectId",
          "slug",
          "displayName",
          "gameFamily",
          "implementationScope",
          "status",
          "donor",
          "targetGame",
        "phase",
        "verificationStatus",
        "verificationChecks",
        "lifecycle",
        "keyPaths",
        "timestamps",
        "notes"
      ],
        "properties": {
          "projectId": {
            "type": "string",
            "minLength": 1
          },
          "slug": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "gameFamily": {
            "type": "string",
            "enum": ["slot", "card", "dice", "crash", "other"]
          },
          "implementationScope": {
            "type": "string",
            "enum": ["slot-first", "universal-architecture", "reference-only"]
          },
          "status": {
            "type": "string",
            "enum": ["planned", "in-progress", "validated", "blocked", "archived"]
          },
          "donor": {
            "$ref": "https://myide.local/schemas/donor-link.schema.json"
          },
          "targetGame": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "displayName", "family", "relationship", "status"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "displayName": {
                "type": "string",
                "minLength": 1
              },
              "family": {
                "type": "string",
                "enum": ["slot", "card", "dice", "crash", "other"]
              },
              "relationship": {
                "type": "string",
                "enum": ["donor-source", "reconstruction-target", "resulting-game", "future-target", "reference-only"]
              },
              "status": {
                "type": "string",
                "enum": ["proven", "validated", "planned", "in-progress", "blocked", "reference-only"]
              },
              "notes": {
                "type": "string"
              },
              "provenNotes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "plannedNotes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "phase": {
            "type": "string",
            "minLength": 1
          },
          "verificationStatus": {
            "type": "string",
            "enum": ["unknown", "in-progress", "verified-replay-slice", "verified-workspace", "blocked", "planned"]
          },
          "verificationChecks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "lifecycle": {
            "type": "object",
            "additionalProperties": false,
            "required": ["currentStage", "stages"],
            "properties": {
              "currentStage": {
                "type": "string",
                "enum": [
                  "donorEvidence",
                  "donorReport",
                  "importMapping",
                  "internalReplay",
                  "targetConcept",
                  "targetBuild",
                  "integration",
                  "qa",
                  "releasePrep"
                ]
              },
              "stages": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "donorEvidence",
                  "donorReport",
                  "importMapping",
                  "internalReplay",
                  "targetConcept",
                  "targetBuild",
                  "integration",
                  "qa",
                  "releasePrep"
                ],
                "properties": {
                  "donorEvidence": { "$ref": "#/$defs/lifecycleStage" },
                  "donorReport": { "$ref": "#/$defs/lifecycleStage" },
                  "importMapping": { "$ref": "#/$defs/lifecycleStage" },
                  "internalReplay": { "$ref": "#/$defs/lifecycleStage" },
                  "targetConcept": { "$ref": "#/$defs/lifecycleStage" },
                  "targetBuild": { "$ref": "#/$defs/lifecycleStage" },
                  "integration": { "$ref": "#/$defs/lifecycleStage" },
                  "qa": { "$ref": "#/$defs/lifecycleStage" },
                  "releasePrep": { "$ref": "#/$defs/lifecycleStage" }
                }
              }
            }
          },
          "keyPaths": {
            "type": "object",
            "additionalProperties": false,
            "required": ["workspaceRegistryPath", "projectRoot", "projectJsonPath", "projectMetaPath"],
            "properties": {
              "workspaceRegistryPath": {
                "type": "string",
                "minLength": 1
              },
              "projectRoot": {
                "type": "string",
                "minLength": 1
              },
              "projectJsonPath": {
                "type": "string",
                "minLength": 1
              },
              "projectMetaPath": {
                "type": "string",
                "minLength": 1
              },
              "donorRoot": {
                "type": "string",
                "minLength": 1
              },
              "reportsRoot": {
                "type": "string",
                "minLength": 1
              },
              "importsRoot": {
                "type": "string",
                "minLength": 1
              },
              "importArtifactPath": {
                "type": "string",
                "minLength": 1
              },
              "internalRoot": {
                "type": "string",
                "minLength": 1
              },
              "runtimeRoot": {
                "type": "string",
                "minLength": 1
              },
              "fixturesRoot": {
                "type": "string",
                "minLength": 1
              },
              "targetRoot": {
                "type": "string",
                "minLength": 1
              },
              "releaseRoot": {
                "type": "string",
                "minLength": 1
              },
              "logsRoot": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "timestamps": {
            "type": "object",
            "additionalProperties": false,
            "required": ["createdAt", "updatedAt"],
            "properties": {
              "createdAt": {
                "type": "string",
                "minLength": 1
              },
              "updatedAt": {
                "type": "string",
                "minLength": 1
              },
              "firstValidatedAt": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "notes": {
            "type": "object",
            "additionalProperties": false,
            "required": ["proven", "planned"],
            "properties": {
              "proven": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "planned": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "assumptions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "unresolvedQuestions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "lifecycleStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["planned", "in-progress", "blocked", "ready-for-review", "verified", "deferred"]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
