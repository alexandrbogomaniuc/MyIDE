{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/localization.schema.json",
  "title": "MyIDE Localization",
  "type": "object",
  "additionalProperties": false,
  "required": ["modelVersion", "localizationId", "ids", "references", "validationNotes", "defaultLocale", "locales"],
  "properties": {
    "modelVersion": {
      "type": "string",
      "const": "0.2.0"
    },
    "localizationId": {
      "type": "string",
      "minLength": 1
    },
    "ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "validationNotes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "defaultLocale": {
      "type": "string",
      "minLength": 2
    },
    "locales": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["locale", "direction", "messageRefs", "strings"],
        "properties": {
          "locale": {
            "type": "string",
            "minLength": 2
          },
          "direction": {
            "type": "string",
            "enum": ["ltr", "rtl"]
          },
          "messageRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "strings": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["refId", "kind"],
      "properties": {
        "refId": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["evidence", "project", "schema", "runtime", "todo"]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
