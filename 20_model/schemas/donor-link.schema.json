{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/donor-link.schema.json",
  "title": "MyIDE Donor Link",
  "type": "object",
  "additionalProperties": false,
  "required": ["donorId", "donorName", "evidenceRoot", "evidenceRefs", "status"],
  "properties": {
    "donorId": {
      "type": "string",
      "minLength": 1
    },
    "donorName": {
      "type": "string",
      "minLength": 1
    },
    "evidenceRoot": {
      "type": "string",
      "minLength": 1
    },
    "captureSessions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": ["proven", "planned", "blocked", "reference-only"]
    },
    "notes": {
      "type": "string"
    }
  }
}
