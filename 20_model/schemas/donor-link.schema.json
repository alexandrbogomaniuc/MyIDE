{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myide.local/schemas/donor-link.schema.json",
  "title": "MyIDE Donor Link",
  "type": "object",
  "additionalProperties": false,
  "required": ["donorId", "donorName", "evidenceRoot", "evidenceRefs", "status"],
  "properties": {
    "donorId": {
      "type": "string",
      "minLength": 1
    },
    "donorName": {
      "type": "string",
      "minLength": 1
    },
    "evidenceRoot": {
      "type": "string",
      "minLength": 1
    },
    "captureSessions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": ["proven", "planned", "blocked", "reference-only"]
    },
    "launchUrl": {
      "type": "string",
      "minLength": 1
    },
    "resolvedLaunchUrl": {
      "type": "string",
      "minLength": 1
    },
    "sourceHost": {
      "type": "string",
      "minLength": 1
    },
    "intakeReportPath": {
      "type": "string",
      "minLength": 1
    },
    "harvestStatus": {
      "type": "string",
      "enum": ["unknown", "harvested", "blocked", "skipped"]
    },
    "harvestManifestPath": {
      "type": "string",
      "minLength": 1
    },
    "harvestedAssetCount": {
      "type": "integer",
      "minimum": 0
    },
    "failedAssetCount": {
      "type": "integer",
      "minimum": 0
    },
    "packageStatus": {
      "type": "string",
      "enum": ["unknown", "packaged", "blocked", "skipped"]
    },
    "packageManifestPath": {
      "type": "string",
      "minLength": 1
    },
    "packageGraphPath": {
      "type": "string",
      "minLength": 1
    },
    "packageFamilyCount": {
      "type": "integer",
      "minimum": 0
    },
    "packageReferencedUrlCount": {
      "type": "integer",
      "minimum": 0
    },
    "packageGraphNodeCount": {
      "type": "integer",
      "minimum": 0
    },
    "packageGraphEdgeCount": {
      "type": "integer",
      "minimum": 0
    },
    "packageUnresolvedCount": {
      "type": "integer",
      "minimum": 0
    },
    "scanStatus": {
      "type": "string",
      "enum": ["unknown", "scanned", "blocked", "skipped"]
    },
    "scanSummaryPath": {
      "type": "string",
      "minLength": 1
    },
    "blockerSummaryPath": {
      "type": "string",
      "minLength": 1
    },
    "nextCaptureTargetsPath": {
      "type": "string",
      "minLength": 1
    },
    "runtimeCandidateCount": {
      "type": "integer",
      "minimum": 0
    },
    "atlasManifestCount": {
      "type": "integer",
      "minimum": 0
    },
    "bundleAssetMapStatus": {
      "type": "string",
      "enum": ["mapped", "blocked", "skipped"]
    },
    "mirrorCandidateStatus": {
      "type": "string",
      "enum": ["strong-partial", "weak-partial", "blocked"]
    },
    "nextCaptureTargetCount": {
      "type": "integer",
      "minimum": 0
    },
    "nextOperatorAction": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
