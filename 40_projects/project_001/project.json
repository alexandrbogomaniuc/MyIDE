  "bindings": [
    {
      "bindingId": "binding.status-message",
      "name": "Active State To Status Banner",
      "kind": "state",
      "from": {
        "type": "state",
        "ref": "activeStateId"
      },
      "to": {
        "type": "scene-node",
        "ref": "node.win-banner",
        "path": "text"
      },
      "transform": {
        "operator": "map",
        "expression": "state->banner"
      }
    },
    {
      "bindingId": "binding.free-spins-counter",
      "name": "Free Spins Remaining Counter",
      "kind": "property",
      "from": {
        "type": "property",
        "ref": "gameState",
        "path": "freeSpins.remaining"
      },
      "to": {
        "type": "scene-node",
        "ref": "node.free-spins-pill",
        "path": "text"
      },
      "transform": {
        "operator": "format",
        "expression": "Free spins: {remaining}/{awarded}"
      }
    },
    {
      "bindingId": "binding.modal-visibility",
      "name": "Free Spins Modal Visibility",
      "kind": "visibility",
      "from": {
        "type": "state",
        "ref": "state.free-spins-trigger"
      },
      "to": {
        "type": "scene-node",
        "ref": "node.free-spins-modal",
        "path": "visible"
      },
      "transform": {
        "operator": "assign"
      }
    },
    {
      "bindingId": "binding.restore-chip",
      "name": "Restart Restore Badge",
      "kind": "event",
      "from": {
        "type": "event",
        "ref": "restart.restore"
      },
      "to": {
        "type": "scene-node",
        "ref": "node.restore-chip",
        "path": "visible",
        "value": true
      },
      "transform": {
        "operator": "assign"
      }
    }
  ],
